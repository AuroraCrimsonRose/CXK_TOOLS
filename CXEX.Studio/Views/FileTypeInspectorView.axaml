<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CXEX.Studio.ViewModels"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="CXEX.Studio.Views.FileTypeInspectorView"
             x:DataType="vm:FileTypeInspectorViewModel">

  <Grid RowDefinitions="Auto, *, Auto" Background="#1E1E1E" Margin="10">

    <Border Grid.Row="0" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10" Margin="0,0,0,10">
      <Grid ColumnDefinitions="Auto, *, Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
          <materialIcons:MaterialIcon Kind="FileSearchOutline" Width="20" Height="20" Foreground="#007ACC"/>
          <TextBlock Text="{Binding FileName}" FontWeight="Bold" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding FileSize}" Foreground="#858585" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{Binding HexRows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,2">

              <TextBlock Text="{Binding Offset}" FontFamily="Consolas, Courier New" Foreground="#569CD6" Width="70"/>

              <ItemsControl ItemsSource="{Binding Bytes}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{Binding Background}" CornerRadius="2" Padding="2" ToolTip.Tip="{Binding ToolTip}">
                      <TextBlock Text="{Binding Text}" FontFamily="Consolas, Courier New" Foreground="{Binding Foreground}" Width="18" TextAlignment="Center"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <TextBlock Text="{Binding AsciiData}" FontFamily="Consolas, Courier New" Foreground="#CE9178" Margin="10,0,0,0"/>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Border Grid.Row="2" Background="#252526" BorderBrush="#3E3E42" BorderThickness="1" Padding="10" Margin="0,10,0,0">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
        <Button Command="{Binding PrevPageCommand}" Content="Previous 4KB" Background="#333333" Foreground="White" BorderThickness="0"/>
        <TextBlock Text="{Binding CurrentPage, StringFormat='Page {0}'}" VerticalAlignment="Center" Foreground="#D4D4D4"/>
        <TextBlock Text="{Binding TotalPages, StringFormat='of {0}'}" VerticalAlignment="Center" Foreground="#858585"/>
        <Button Command="{Binding NextPageCommand}" Content="Next 4KB" Background="#333333" Foreground="White" BorderThickness="0"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>