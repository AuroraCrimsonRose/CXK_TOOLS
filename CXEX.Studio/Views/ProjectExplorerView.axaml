<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CXEX.Studio.ViewModels"
             xmlns:models="using:CXEX.Studio.Models"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="CXEX.Studio.Views.ProjectExplorerView"
             x:DataType="vm:ProjectExplorerViewModel"
             MinWidth="200">

  <!-- No internal title band: the dock tab already shows "Explorer". -->
  <TreeView ItemsSource="{Binding RootNodes}" Background="{DynamicResource CxSurface1Brush}"
            Padding="0,5" x:CompileBindings="False">

    <TreeView.Styles>
      <Style Selector="TreeViewItem">
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Padding" Value="2,0"/>
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
      </Style>
    </TreeView.Styles>

    <TreeView.ItemTemplate>
      <TreeDataTemplate DataType="models:FileTreeNode" ItemsSource="{Binding Children}">
        <StackPanel Orientation="Horizontal" Spacing="6" Background="Transparent"
                    ToolTip.Tip="{Binding FullPath}"
                    DoubleTapped="OnItemDoubleTapped">
          <materialIcons:MaterialIcon Kind="{Binding Icon}" Width="16" Height="16"
                                      Foreground="{Binding IconColor}" />
          <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"
                     Foreground="{Binding TextColor}" />
        </StackPanel>
      </TreeDataTemplate>
    </TreeView.ItemTemplate>
  </TreeView>
</UserControl>
