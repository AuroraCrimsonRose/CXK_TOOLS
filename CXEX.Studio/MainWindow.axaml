<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CXEX.Studio.ViewModels"
        xmlns:idc="using:Dock.Avalonia.Controls"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="CXEX.Studio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title=""
        Background="#1E1E1E"
        Foreground="#D4D4D4"
        Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="30"
        WindowDecorations="Full">

  <Window.Resources>
    <Color x:Key="SystemAccentColor">#007ACC</Color>
    <Color x:Key="SystemAccentColorDark1">#007ACC</Color>
    <Color x:Key="SystemAccentColorDark2">#007ACC</Color>
    <Color x:Key="SystemAccentColorDark3">#007ACC</Color>
    <Color x:Key="SystemAccentColorLight1">#007ACC</Color>
    <Color x:Key="SystemAccentColorLight2">#007ACC</Color>
    <Color x:Key="SystemAccentColorLight3">#007ACC</Color>
    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="{StaticResource SystemAccentColor}" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.ActivityButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button.ActivityButton:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2A2A2A"/>
    </Style>

    <Style Selector="Button.ActivityButton materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#858585"/>
    </Style>
    <Style Selector="Button.ActivityButton:pointerover materialIcons|MaterialIcon">
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Menu">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#2D2D2D"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="30, *, Auto">

    <Grid Grid.Row="0" Background="#181818">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Menu Grid.Column="0" HorizontalAlignment="Left">
        <MenuItem Header="_File">
          <MenuItem Header="_Open Project..." Click="OnOpenProjectClicked" />
          <Separator/>
          <MenuItem Header="_Exit" />
        </MenuItem>
        <MenuItem Header="_Edit" />
        <MenuItem Header="_View">
          <MenuItem Header="_Dashboard" Command="{Binding OpenDashboardCommand}" />
          <MenuItem Header="_Emulator" Command="{Binding OpenEmulatorCommand}" />
          <MenuItem Header="_Hex Inspector" Command="{Binding OpenHexInspectorCommand}" />
          <Separator/>
          <MenuItem Header="_Explorer" Command="{Binding ShowExplorerCommand}" />
          <Separator/>
          <MenuItem Header="Build _Output" Command="{Binding ToggleBottomPanelCommand}" />
        </MenuItem>
        <MenuItem Header="_Tools">
          <MenuItem Header="Hex Inspector" Command="{Binding OpenHexInspectorCommand}" />
          <MenuItem Header="Emulator" Command="{Binding OpenEmulatorCommand}" />
        </MenuItem>
        <MenuItem Header="_Help" />
      </Menu>

      <Border Grid.Column="1" Background="Transparent" WindowDecorationProperties.ElementRole="TitleBar">
        <TextBlock Text="CXEX.Studio - Kernel Developer Suite"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#858585" FontSize="12" Margin="0,0,140,0"
                   IsHitTestVisible="False"/>
      </Border>
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="Auto, *">

      <Border Grid.Column="0" Width="48" Background="#181818"
              BorderBrush="#2D2D2D" BorderThickness="0,0,1,0">
        <DockPanel VerticalAlignment="Stretch">
          <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,4,0,0">
            <Button Classes="ActivityButton" ToolTip.Tip="Explorer (Project Tree)" Command="{Binding ShowExplorerCommand}">
              <materialIcons:MaterialIcon Kind="FolderOutline" Width="22" Height="22"/>
            </Button>
            <Button Classes="ActivityButton" ToolTip.Tip="Search Codebase">
              <materialIcons:MaterialIcon Kind="Magnify" Width="22" Height="22"/>
            </Button>
            <Button Classes="ActivityButton" ToolTip.Tip="Emulator / Run" Command="{Binding OpenEmulatorCommand}">
              <materialIcons:MaterialIcon Kind="BugOutline" Width="22" Height="22"/>
            </Button>
          </StackPanel>
          <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,4">
            <Button Classes="ActivityButton" ToolTip.Tip="Toggle Build Output" Command="{Binding ToggleBottomPanelCommand}">
              <materialIcons:MaterialIcon Kind="ViewSplitHorizontal" Width="22" Height="22"/>
            </Button>
            <Button Classes="ActivityButton" ToolTip.Tip="Settings">
              <materialIcons:MaterialIcon Kind="CogOutline" Width="22" Height="22"/>
            </Button>
          </StackPanel>
        </DockPanel>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="*, Auto, Auto">

        <Border Grid.Row="0" Background="#1E1E1E" Padding="2">
          <idc:DockControl Layout="{Binding Layout}" />
        </Border>

        <GridSplitter Grid.Row="1" Height="4" ResizeDirection="Rows"
                      HorizontalAlignment="Stretch" Background="#2D2D2D"
                      IsVisible="{Binding IsBottomPanelVisible}"/>

        <Border Grid.Row="2" Height="200" Background="#181818"
                BorderBrush="#2D2D2D" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsBottomPanelVisible}">
          <Grid RowDefinitions="Auto, *">

            <!-- panel header: title, input, build/cancel, status -->
            <Grid Grid.Row="0" Background="#1E1E1E" MinHeight="36" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Column="0" Text="BUILD OUTPUT" VerticalAlignment="Center"
                         Margin="10,0" FontSize="11" FontWeight="SemiBold" Foreground="#858585"/>
              <TextBox Grid.Column="1" Watermark="input .elf path" VerticalAlignment="Center"
                       Margin="6,5" Height="26" FontSize="11"
                       Text="{Binding Build.ProjectPath, Mode=TwoWay}"/>
              <ComboBox Grid.Column="2" SelectedItem="{Binding Build.OutputType, Mode=TwoWay}"
                        VerticalAlignment="Center" Margin="2,5" Width="84" Height="26" FontSize="11">
                <ComboBoxItem Content="user"/>
                <ComboBoxItem Content="os"/>
                <ComboBoxItem Content="boot"/>
                <ComboBoxItem Content="kernel"/>
              </ComboBox>
              <Button Grid.Column="3" Content="Build" Margin="2,5" Height="26" Padding="10,0" FontSize="11"
                      Command="{Binding Build.BuildCommand}"/>
              <Button Grid.Column="4" Content="Cancel" Margin="2,5" Height="26" Padding="8,0" FontSize="11"
                      Command="{Binding Build.CancelCommand}"/>
              <Button Grid.Column="5" Content="_" Margin="2,5,8,5" Height="26" Padding="8,0" FontSize="11"
                      ToolTip.Tip="Hide panel" Command="{Binding ToggleBottomPanelCommand}"/>
            </Grid>

            <!-- log body -->
            <ScrollViewer Grid.Row="1" Padding="10,4" Background="#181818">
              <ItemsControl ItemsSource="{Binding Build.Log}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" FontFamily="Cascadia Code,Consolas,monospace"
                               FontSize="12" Foreground="#CCCCCC" TextWrapping="NoWrap"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

          </Grid>
        </Border>

      </Grid>

    </Grid>

    <Border Grid.Row="2" Height="22" Background="#007ACC">
      <Grid ColumnDefinitions="Auto, *, Auto" Margin="10,0">
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
          <TextBlock Text="Ready" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
          <TextBlock Text="|" FontSize="11" Foreground="#52B2FF"/>
          <TextBlock Text="CXEX Environment: Active" FontSize="11" Foreground="White"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
          <TextBlock Text="Ln 1, Col 1" FontSize="11" Foreground="White"/>
          <TextBlock Text="UTF-8" FontSize="11" Foreground="White"/>
          <TextBlock Text="CRLF" FontSize="11" Foreground="White"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="0" Grid.RowSpan="3" Background="#A0000000" IsVisible="{Binding IsBusy}" ZIndex="999">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
        <ProgressBar IsIndeterminate="True" Width="150" Height="4" Foreground="#007ACC" Background="#333333"/>
        <TextBlock Text="{Binding BusyText}" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
      </StackPanel>
    </Grid>

  </Grid>
</Window>